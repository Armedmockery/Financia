  m_EditorClassIdentifier: Assembly-CSharp::RoomTaxData
  roomRewards:
  - {fileID: 4983730577362295110, guid: d14a4d305ecd64cdfba7ab3d40c49364, type: 3}
  minRewards: 1
  maxRewards: 1
  roomChoices:
  - choiceText: Report All Income (Incl. Freelance)
    wisdomValue: 1
    explanation: Declaring all income avoids penalties and builds long-term financial
      credibility. When income records are matched digitally, accurate reporting
      prevents notices and future complications.
  - choiceText: Ignore Small Side Income
    wisdomValue: -1
    explanation: Even small undeclared income can trigger penalties if detected.
      Tax systems track financial data, and repeated underreporting increases audit
      risk and financial stress.
  - choiceText: "Not Sure \u2013 Check Form 26AS First"
    wisdomValue: 1
    explanation: Verifying income records before filing reduces errors. Cross-checking
      official records helps you avoid mismatches that could delay refunds or raise
      questions later.
